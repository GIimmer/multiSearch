{
  "manifest_version": 3,
  "name": "CtrlEff",
  "version": "1.0.0",
  "description": "Enhanced multi-term find-in-page with cross-page persistence",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_title": "CtrlEff — Enhanced Find"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "MacCtrl+Shift+F"
      },
      "description": "Toggle CtrlEff search panel"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  }
}
