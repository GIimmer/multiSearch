{
  "manifest_version": 3,
  "name": "MultiSearch",
  "browser_specific_settings": {
    "gecko": {
      "id": "multisearch@glimmer",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "version": "1.0.0",
  "description": "Enhanced multi-term find-in-page with cross-page persistence",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_title": "MultiSearch — Enhanced Find"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Alt+S",
        "mac": "Command+Alt+S"
      },
      "description": "Toggle MultiSearch panel"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/state.js",
        "content/highlighter.js",
        "content/panel.js",
        "content/init.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/panel.html", "content/panel.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  }
}
